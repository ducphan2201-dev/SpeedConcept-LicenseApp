    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^5.12.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
